# RabbitMQ (shared by queue_workers + mini_bot)
NGROK_TCP_HOST=7.tcp.ngrok.io
NGROK_TCP_PORT=21850
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# MongoDB — queue_workers
CALL_DB_URL=mongodb+srv://user:pass@cluster.mongodb.net/production
SMS_DB_URL=mongodb+srv://user:pass@cluster.mongodb.net/production
CLIENTS_DB_URL=mongodb+srv://user:pass@cluster.mongodb.net/tvmount

# MongoDB — mini_bot (defaults to CLIENTS_DB_URL if not set)
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/

# Telegram — mini_bot
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=-1234567890

# queue_workers
NODE_ENV=production
