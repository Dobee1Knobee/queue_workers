# RabbitMQ (shared by queue_workers + mini_bot)
NGROK_TCP_HOST=7.tcp.ngrok.io
NGROK_TCP_PORT=21850
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# MongoDB — queue_workers
CALL_DB_URL=mongodb+srv://user:pass@cluster.mongodb.net/production
SMS_DB_URL=mongodb+srv://user:pass@cluster.mongodb.net/production
CLIENTS_DB_URL=mongodb+srv://user:pass@cluster.mongodb.net/tvmount

# MongoDB — mini_bot (defaults to CLIENTS_DB_URL if not set)
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/

# Telegram — mini_bot
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=-1234567890

# queue_workers
NODE_ENV=production

# Telegram Gateway integration (optional)
# If TELEGRAM_GATEWAY_ENABLED=true, repeat notifications are sent to gateway directly
# and claim callbacks are expected on POST /internal/telegram/events (this service).
TELEGRAM_GATEWAY_ENABLED=false
TELEGRAM_GATEWAY_URL=https://telegram.it.tvmountmaster.com
TELEGRAM_GATEWAY_CALLER_ID=zoom-income-lead-claim
TELEGRAM_GATEWAY_API_KEY=replace-with-issued-key
TELEGRAM_GATEWAY_CHAT_ID=-1234567890
# or use chat alias configured in gateway app config:
# TELEGRAM_GATEWAY_CHAT_ALIAS=managers

# Optional hard checks for inbound events from gateway
TELEGRAM_GATEWAY_EXPECTED_APP_KEY=manager-control
TELEGRAM_GATEWAY_EXPECTED_ROUTE_KEY=support-bot
